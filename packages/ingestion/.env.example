# Environment Configuration for Event Ingestion Service
# Copy this file to .env and configure for your environment

# ============================================================================
# Environment
# ============================================================================
NODE_ENV=development

# ============================================================================
# Database Configuration
# ============================================================================
# Option 1: Use DATABASE_URL (recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/ingestion

# Option 2: Use individual variables (uncomment if not using DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5434
# DB_NAME=ingestion
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_POOL_MAX=20
# DB_IDLE_TIMEOUT=30000
# DB_CONNECT_TIMEOUT=2000

# ============================================================================
# API Configuration
# ============================================================================
# For local testing with mock API
API_BASE_URL=http://localhost:3000/api/v1
# For Docker environment: http://mock-api:3000/api/v1
# For real API: http://datasync-dev-alb-101078500.us-east-1.elb.amazonaws.com/api/v1

API_KEY=mock_key_not_needed

# API request settings
API_TIMEOUT=30000
API_RETRIES=3

# ============================================================================
# Worker Configuration
# ============================================================================
# Number of parallel workers (adjust based on rate limits)
WORKER_CONCURRENCY=10

# Events per API request (max supported by API)
PAGE_SIZE=1000

# Events per database batch insert
BATCH_SIZE=500

# ============================================================================
# Logging
# ============================================================================
# How often to log progress (milliseconds)
LOG_INTERVAL=5000
